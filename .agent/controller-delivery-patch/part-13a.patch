+
+async function readOptional(filePath: string): Promise<string | null> {
+  try {
+    await access(filePath);
+    return await readFile(filePath, 'utf8');
+  } catch (error) {
+    if ((error as NodeJS.ErrnoException).code === 'ENOENT') return null;
+    throw error;
+  }
+}
+
+export async function generateDeliverySlice(
+  kind: DeliveryGenerationKind,
+  targetValue: string,
+  options: DeliveryGenerationOptions = {},
+): Promise<DeliveryGenerationResult> {
+  const root = path.resolve(options.root ?? process.cwd());
+  const target = parseTarget(targetValue);
+  const plans = plan(kind, target);
+  const created: string[] = [];
+  const skipped: string[] = [];
+  const overwritten: string[] = [];
+  const conflicts: string[] = [];
+
+  for (const item of plans) {
+    const absolute = path.join(root, item.file);
+    const current = await readOptional(absolute);
+    if (current === item.content) {
+      skipped.push(item.file);
+    } else if (current !== null && !options.force) {
+      conflicts.push(item.file);
+    } else if (current === null) {
+      created.push(item.file);
+    } else {
+      overwritten.push(item.file);
+    }
+  }
+
+  if (conflicts.length > 0) {
+    throw new DocumentationCommandError(
+      'DELIVERY_GENERATOR_CONFLICT',
+      `A generátor nem ír felül kézi vagy eltérő fájlt: ${conflicts.join(', ')}`,
+      conflicts[0],
+    );
+  }
+
+  if (!options.dryRun) {
+    for (const item of plans) {
+      if (skipped.includes(item.file)) continue;
+      const absolute = path.join(root, item.file);
+      await mkdir(path.dirname(absolute), { recursive: true });
+      await writeFile(absolute, item.content, 'utf8');
+    }
+  }
+
+  return {
+    kind,
+    target: targetValue,
+    dryRun: options.dryRun ?? false,
+    created,
+    skipped,
+    overwritten,
+  };
+}
