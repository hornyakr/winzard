# application-shell — process-start, internal
APP_URL=http://localhost:3000
APP_NAME=Winzard Reference
APP_STAGE=local
LOG_LEVEL=debug

# kernel-configuration — build, deployment, runtime and network invariants
APP_ID=winzard-reference
APP_REGION=local
GIT_COMMIT=0000000
BUILD_ID=local-build
DEPLOYMENT_ID=local-deployment
SOURCE_DATE_EPOCH=0
DEFAULT_LOCALE=hu
ENABLED_LOCALES=hu,en
TRUSTED_HOSTS=localhost:3000,localhost,127.0.0.1,[::1]
SERVER_ACTION_ALLOWED_ORIGINS=localhost:3000
SERVER_ACTION_BODY_SIZE_LIMIT=1mb
# Leave empty for local development; release builds require canonical base64 for a 32-byte key.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
TRUSTED_PROXY_MODE=none
TRUSTED_PROXY_CIDRS=127.0.0.1/32
TRUSTED_PROXY_HOPS=1
NEXT_DIST_DIR=.next
NEXT_OUTPUT_STANDALONE=false
PRODUCTION_BROWSER_SOURCE_MAPS=false
PRODUCTION_BROWSER_SOURCE_MAPS_WAIVER=not-required
KERNEL_VERBOSE_DIAGNOSTICS=false
CACHE_SCHEMA_VERSION=1
COMPOSITION_HASH=auto
RUNTIME_WRITABLE_ROOT=/tmp/winzard
WORKER_CONCURRENCY=4
WORKER_VISIBILITY_TIMEOUT_MS=60000
WORKER_SHUTDOWN_GRACE_MS=30000
WORKER_POLL_INTERVAL_MS=1000

# public-ui — build-time, public; changing it requires a rebuild
NEXT_PUBLIC_APP_NAME=Winzard Reference
