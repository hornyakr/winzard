{
  "name": "winzard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Convention-driven application platform built on Next.js.",
  "packageManager": "pnpm@11.13.1",
  "engines": { "node": ">=24 <25", "pnpm": ">=11 <12" },
  "scripts": {
    "dev": "next dev",
    "build": "pnpm db:generate && next build",
    "start": "next start",
    "typegen": "next typegen",
    "typecheck": "pnpm typegen && tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:e2e": "tsx tools/e2e/lucky-number.smoke.ts",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:seed": "prisma db seed",
    "forge": "tsx tools/forge/cli.ts",
    "doctor": "pnpm forge doctor",
    "verify": "pnpm db:validate && pnpm db:generate && pnpm typecheck && pnpm lint && pnpm test && pnpm forge check && pnpm build && pnpm test:e2e"
  },
  "winzard": { "profile": "webapp", "schemaVersion": 1 },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "next": "16.2.10",
    "pg": "8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "24.10.9",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "dotenv": "17.4.2",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
