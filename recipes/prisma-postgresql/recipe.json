{
  "schemaVersion": 1,
  "name": "prisma-postgresql",
  "provides": ["prisma-postgresql"],
  "requires": ["next-app", "forge"],
  "dependencies": {
    "runtime": ["@prisma/adapter-pg", "@prisma/client", "pg", "server-only", "zod"],
    "development": ["@types/pg", "dotenv", "prisma", "tsx"]
  },
  "environment": ["DATABASE_URL", "DATABASE_POOL_MAX", "DATABASE_CONNECTION_TIMEOUT_MS"],
  "files": [
    "prisma.config.ts",
    "prisma/schema.prisma",
    "src/platform/database/database-env.server.ts",
    "src/platform/database/client.ts"
  ]
}
