# application-shell — process-start, internal
APP_URL=http://localhost:3000
APP_NAME=Winzard Webapp
APP_STAGE=local
LOG_LEVEL=debug

# public-ui — build-time, public; changing it requires a rebuild
NEXT_PUBLIC_APP_NAME=Winzard Webapp

# prisma-postgresql — process-start; DATABASE_URL is a secret
DATABASE_URL=postgresql://user:password@localhost:5432/winzard
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=5000
