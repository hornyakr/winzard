{
  "name": "winzard-webapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typegen": "next typegen",
    "typecheck": "pnpm typegen && tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "forge": "winzard-forge",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed"
  },
  "winzard": {
    "schemaVersion": 1,
    "profile": "webapp",
    "capabilities": [
      "next-app",
      "forge",
      "presentation-contract",
      "modular-application",
      "liveness",
      "prisma-postgresql",
      "database-readiness"
    ]
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "pg": "8.22.0",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "24.10.9",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "@types/pg": "8.20.0",
    "dotenv": "17.4.2",
    "prisma": "7.8.0",
    "tsx": "4.23.1"
  }
}
