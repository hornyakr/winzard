{
  "name": "winzard-webapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typegen": "next typegen",
    "typecheck": "pnpm typegen && tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "forge": "winzard-forge",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:check": "forge database:check",
    "db:connections": "forge database:connections",
    "db:schema": "forge schema:list",
    "db:schema:docs": "forge schema:docs",
    "db:migrations": "forge migration:list",
    "db:migrations:check": "forge migration:check",
    "db:repositories": "forge repository:list",
    "db:repositories:check": "forge repository:check",
    "db:query-plans": "forge query:plans"
  },
  "winzard": {
    "schemaVersion": 1,
    "profile": "webapp",
    "capabilities": [
      "next-app",
      "kernel-configuration",
      "http-kernel",
      "service-composition",
      "forge",
      "presentation-contract",
      "modular-application",
      "liveness",
      "prisma-postgresql",
      "database-readiness",
      "event-dispatching",
      "integration-messaging",
      "transactional-outbox"
    ]
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "pg": "8.22.0",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "24.10.9",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "dotenv": "17.4.2",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
