generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model OutboxMessage {
  id                String   @id
  source            String
  type              String
  subject           String?
  schemaVersion     Int
  aggregateId       String?
  aggregateSequence BigInt?
  tenantId          String?
  correlationId     String?
  causationId       String?
  payload            Json
  metadata           Json
  status             String   @default("pending")
  attempts           Int      @default(0)
  availableAt        DateTime @default(now())
  lockedAt           DateTime?
  lockedBy           String?
  publishedAt        DateTime?
  lastErrorCode      String?
  createdAt          DateTime @default(now())

  @@unique([source, id])
  @@index([status, availableAt])
  @@index([aggregateId, aggregateSequence])
}

model InboxMessage {
  consumerId  String
  source      String
  eventId     String
  tenantId    String?
  processedAt DateTime @default(now())
  resultHash  String?

  @@id([consumerId, source, eventId])
  @@index([tenantId, processedAt])
}

model DeadLetterMessage {
  id               String   @id
  consumerId       String?
  source           String
  eventId          String
  eventType        String
  schemaVersion    Int
  attemptCount     Int
  firstFailureAt   DateTime
  lastFailureAt    DateTime
  errorCode        String
  payloadHash      String
  correlationId    String?
  tenantId         String?
  operatorAction   String?
  createdAt        DateTime @default(now())

  @@index([consumerId, lastFailureAt])
  @@index([tenantId, lastFailureAt])
}
