{
  "compilerOptions": {
    "target": "ES2022", "lib": ["dom", "dom.iterable", "es2023"], "strict": true,
    "noEmit": true, "esModuleInterop": true, "module": "esnext", "moduleResolution": "bundler",
    "resolveJsonModule": true, "isolatedModules": true, "jsx": "react-jsx", "incremental": true,
    "plugins": [{ "name": "next" }], "baseUrl": ".", "paths": { "@/*": ["./src/*"] }
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", "tools/**/*.ts", "tests/**/*.ts", "*.config.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "src/generated/prisma"]
}
